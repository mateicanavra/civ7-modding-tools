# === Denylist Strategy ===
# This .gitignore file uses a "denylist" strategy. Only explicitly listed
# files and directories will be ignored, which is a common and maintainable
# approach.

# Node/npm build outputs and sensitive files
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.*
coverage/
**/*.tgz
*.tmp
*.log
*.tsbuildinfo
dist/

# CLI outputs
out/**
.civ7/**
!.civ7/
!.civ7/outputs/
!.civ7/outputs/resources/
packages/cli/oclif.manifest.json
tools/habitat/oclif.manifest.json

# Docs build output (declared as Nx outputs)
apps/docs/dist/

# Playground generated examples
apps/playground/example-generated-mod/

# Built mod outputs
# mods/*/mod/
mods/mod-swooper-civ-dacia/mod/
mods/mod-swooper-maps/mod/maps/

# MapGen Studio live-run config. This is written by Studio for ad hoc launches
# and must not become a shipped built-in map preset.
mods/mod-swooper-maps/src/maps/configs/studio-current.config.json
mods/mod-swooper-maps/src/maps/generated/studio-current.ts


# OS/system files
.DS_Store
**/.DS_Store
Thumbs.db

# IDEs/editors/settings
.vscode/
.idea/
*.code-workspace
.cursor/
.mcp.json
.roo/
.zed/

# Project-specific ignores
# Modify this to match your zip output
apps/docs/public/civ7-official/resources/
.early.coverage/


# AI-generated artifacts and archives
.ai/*
!.ai/archive/
!.ai/archive/**
.claude/settings.local.json


# Repomix artifacts
**/repomix-*.json
**/repomix-*.xml
!**/repomix-*.config.json

# Local worktrees and scratchpads
.worktrees/
**/*.scratch.md
.scratch/

# Nx
.nx/cache
.nx/workspace-data

# Grit local caches/modules
.grit/.gritmodules/
.grit/cache/
.habitat/cache/
