{
  "id": "block_unapproved_base_standard_boundary_leaks",
  "title": "Block Unapproved Base-Standard Boundary Leaks",
  "ownerTool": "command-check",
  "ownerProject": "habitat",
  "lane": "enforced",
  "scope": "packages/**",
  "forbids": "/base-standard/ imports outside packages/civ7-adapter",
  "why": "The adapter is the sole owner of Civ7 engine surfaces; leaks make engine coupling untrackable.",
  "detect": [
    ".habitat/civ7/platform/blueprints/civ7-adapter/boundary/check/block_unapproved_base_standard_boundary_leaks/block_unapproved_base_standard_boundary_leaks.check.sh"
  ],
  "remediate": null,
  "message": "Move the /base-standard/ import into @civ7/adapter, or remove it from the allowlisted script debt.",
  "exceptionPath": "none",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "packages/**"
      ]
    },
    {
      "kind": "project-owner"
    }
  ]
}
