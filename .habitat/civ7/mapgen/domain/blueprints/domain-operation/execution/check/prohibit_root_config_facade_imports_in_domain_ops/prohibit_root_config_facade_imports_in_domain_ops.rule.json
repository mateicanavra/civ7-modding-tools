{
  "id": "prohibit_root_config_facade_imports_in_domain_ops",
  "title": "Prohibit Root Config Facade Imports In Domain Ops",
  "ownerTool": "source-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/src/domain/**/ops/**/*.ts",
  "forbids": "ops importing domain-root config facades via parent traversal",
  "why": "Ops receive normalized config contracts; root config facades are composition surfaces.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "source-check"
  ],
  "remediate": null,
  "message": "Do not import domain-root config facades from ops.",
  "exceptionPath": "none",
  "patternName": "prohibit_root_config_facade_imports_in_domain_ops",
  "hookCheck": true,
  "scanRoots": [
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/mod-swooper-maps/src/domain/**/ops/**/*.ts"
      ]
    }
  ]
}
