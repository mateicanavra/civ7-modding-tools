{
  "ownerTool": "grit-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "foundation domain, foundation standard stage, and maps source surfaces",
  "forbids": "the retired computeTectonics source token in foundation surfaces",
  "why": "Foundation surfaces must depend on decomposed tectonics operations rather than the retired monolithic computeTectonics contract.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "grit-check"
  ],
  "remediate": null,
  "message": "Remove legacy computeTectonics references from foundation surfaces.",
  "hookCheck": true,
  "scanRoots": [
    "mods/mod-swooper-maps/src/domain/foundation",
    "mods/mod-swooper-maps/src/recipes/standard/stages/foundation",
    "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-lithosphere",
    "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-mantle",
    "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-orogeny",
    "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-projection",
    "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-tectonics",
    "mods/mod-swooper-maps/src/maps"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/mod-swooper-maps/src/domain/foundation/**/*.ts",
        "mods/mod-swooper-maps/src/recipes/standard/stages/foundation/**/*.ts",
        "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-lithosphere/**/*.ts",
        "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-mantle/**/*.ts",
        "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-orogeny/**/*.ts",
        "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-projection/**/*.ts",
        "mods/mod-swooper-maps/src/recipes/standard/stages/foundation-tectonics/**/*.ts",
        "mods/mod-swooper-maps/src/maps/**/*.ts",
        "mods/mod-swooper-maps/src/maps/**/*.json"
      ]
    }
  ]
}
