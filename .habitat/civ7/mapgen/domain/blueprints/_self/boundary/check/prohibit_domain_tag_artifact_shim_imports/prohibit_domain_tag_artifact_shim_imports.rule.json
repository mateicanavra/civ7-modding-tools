{
  "id": "prohibit_domain_tag_artifact_shim_imports",
  "title": "Prohibit Domain Tag Artifact Shim Imports",
  "ownerTool": "grit-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/src/**/*.ts",
  "forbids": "@mapgen/domain/tags and @mapgen/domain/artifacts shim imports",
  "why": "Retired tag and artifact shims should not become public domain ownership again.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "grit-check"
  ],
  "remediate": null,
  "message": "Use the current owning public surface instead of retired domain tag/artifact shims.",
  "exceptionPath": "none",
  "patternName": "prohibit_domain_tag_artifact_shim_imports",
  "hookCheck": true,
  "scanRoots": [
    "mods/mod-swooper-maps/src/domain",
    "mods/mod-swooper-maps/src/recipes",
    "mods/mod-swooper-maps/src/maps"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/mod-swooper-maps/src/**/*.ts"
      ]
    }
  ]
}
