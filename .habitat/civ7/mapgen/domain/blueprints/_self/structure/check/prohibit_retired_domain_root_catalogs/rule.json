{
  "ownerTool": "grit-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/src/domain/**/{tags,artifacts}.ts",
  "forbids": "domain-root tag/artifact catalogs",
  "why": "Catalogs belong to owned public surfaces, not obsolete root files.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "grit-check"
  ],
  "remediate": null,
  "message": "Move domain-root catalogs to the owning public surface.",
  "hookCheck": true,
  "scanRoots": [
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/mod-swooper-maps/src/domain/**/tags.ts",
        "mods/mod-swooper-maps/src/domain/**/artifacts.ts"
      ]
    }
  ]
}
