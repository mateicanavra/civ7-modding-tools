{
  "schemaVersion": 2,
  "id": "ensure_studio_worker_bundle_is_browser_safe",
  "title": "Ensure Studio Worker Bundle Is Browser Safe",
  "placement": {
    "niche": "civ7/mapgen/studio/browser-worker",
    "blueprint": "_self",
    "category": "execution"
  },
  "operation": {
    "kind": "check"
  },
  "ownerProject": "mapgen-studio",
  "lane": "enforced",
  "forbids": "Studio worker bundle leaking Civ7 runtime imports, engine globals, or Node builtins",
  "why": "The Studio browser worker must stay browser-safe and use recipe artifacts instead of runtime-only Civ7 surfaces.",
  "remediate": "Move forbidden runtime access behind server/direct-control or artifact boundaries.",
  "message": "Studio worker bundle contains forbidden runtime or Node references.",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": ["apps/mapgen-studio/dist/**/*.js", "apps/mapgen-studio/dist/**/*.mjs"]
    },
    {
      "kind": "project-owner"
    }
  ],
  "supportFiles": {
    "baseline": ".habitat/civ7/mapgen/studio/browser-worker/rules/ensure_studio_worker_bundle_is_browser_safe/baseline.json"
  },
  "graphDependencies": [
    {
      "project": "mapgen-studio",
      "target": "build:vite"
    }
  ],
  "runner": {
    "name": "habitat",
    "mode": "script",
    "runtime": "node",
    "files": {
      "script": ".habitat/civ7/mapgen/studio/browser-worker/rules/ensure_studio_worker_bundle_is_browser_safe/check.mjs"
    }
  }
}
