{
  "schemaVersion": 2,
  "id": "prohibit_studio_rpc_eventhub_lifecycle_leaks",
  "title": "Prohibit Studio Rpc Eventhub Lifecycle Leaks",
  "placement": {
    "niche": "civ7/mapgen/studio/server",
    "blueprint": "_self",
    "category": "boundary"
  },
  "operation": {
    "kind": "check"
  },
  "ownerProject": "mapgen-studio",
  "lane": "enforced",
  "forbids": "daemon-owned EventHub lifecycle, EventHub injection into RPC handler calls, or EventHub exposure from Studio server context",
  "why": "The daemon mounts Studio RPC; EventHub lifecycle belongs inside the Studio runtime context.",
  "remediate": "Keep EventHub creation and shutdown inside the Studio runtime context.",
  "message": "Studio RPC daemon leaked EventHub lifecycle ownership.",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "apps/mapgen-studio/src/server/daemon/daemon.ts",
        "apps/mapgen-studio/src/server/studio/context.ts"
      ]
    },
    {
      "kind": "project-owner"
    }
  ],
  "scanRoots": ["apps/mapgen-studio/src/server/daemon", "apps/mapgen-studio/src/server/studio"],
  "hookCheck": true,
  "supportFiles": {
    "baseline": ".habitat/civ7/mapgen/studio/server/rules/prohibit_studio_rpc_eventhub_lifecycle_leaks/baseline.json"
  },
  "runner": {
    "name": "grit",
    "files": {
      "pattern": ".habitat/civ7/mapgen/studio/server/rules/prohibit_studio_rpc_eventhub_lifecycle_leaks/pattern.md"
    },
    "patternName": "prohibit_studio_rpc_eventhub_lifecycle_leaks"
  }
}
