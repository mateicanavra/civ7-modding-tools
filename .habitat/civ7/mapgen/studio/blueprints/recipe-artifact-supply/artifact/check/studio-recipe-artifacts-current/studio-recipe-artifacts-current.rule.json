{
  "id": "studio-recipe-artifacts-current",
  "title": "Verify Studio Recipe Artifacts Are Current",
  "ownerTool": "command-check",
  "ownerProject": "mapgen-studio",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/src/domain/**, mods/mod-swooper-maps/src/maps/**, mods/mod-swooper-maps/src/recipes/**, packages/mapgen-core/src/**",
  "forbids": "missing or stale Studio recipe artifact dist outputs",
  "why": "Studio consumes generated recipe schema/default/preset artifacts; stale or partial dist state breaks config and browser runtime assumptions.",
  "detect": [
    "node",
    ".habitat/civ7/mapgen/studio/blueprints/recipe-artifact-supply/artifact/check/studio-recipe-artifacts-current/studio-recipe-artifacts-current.check.mjs"
  ],
  "remediate": "Run `bun run --cwd apps/mapgen-studio ensure:studio-recipe-artifacts` or rebuild mod-swooper-maps studio recipe artifacts.",
  "message": "Studio recipe artifacts must be present and fresh.",
  "exceptionPath": "none",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/mod-swooper-maps/src/domain/**",
        "mods/mod-swooper-maps/src/maps/**",
        "mods/mod-swooper-maps/src/recipes/**",
        "mods/mod-swooper-maps/scripts/generate-map-artifacts.ts",
        "mods/mod-swooper-maps/scripts/generate-studio-recipe-types.ts",
        "mods/mod-swooper-maps/package.json",
        "mods/mod-swooper-maps/tsup.studio-recipes.config.ts",
        "packages/mapgen-core/src/**"
      ]
    },
    {
      "kind": "project-owner"
    }
  ]
}
