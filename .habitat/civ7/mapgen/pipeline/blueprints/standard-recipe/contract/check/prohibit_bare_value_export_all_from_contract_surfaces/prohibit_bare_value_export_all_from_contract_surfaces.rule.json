{
  "id": "prohibit_bare_value_export_all_from_contract_surfaces",
  "title": "Prohibit Bare Value Export-All From Contract Surfaces",
  "ownerTool": "grit-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "contract/public-surface TypeScript files",
  "forbids": "bare value export * in contract/public-surface files; export type * is allowed",
  "why": "Contract/public surfaces should publish named values; type-star exports remain safe type-only API aggregation.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "grit-check"
  ],
  "remediate": null,
  "message": "Replace value export * with named exports, or use export type * for type-only surfaces.",
  "exceptionPath": "none",
  "patternName": "prohibit_bare_value_export_all_from_contract_surfaces",
  "hookCheck": true,
  "scanRoots": [
    "mods/mod-swooper-maps/src/recipes",
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/*/src/recipes/**/stages/**/steps/**/*contract.ts",
        "mods/*/src/domain/**/ops/**/contract.ts",
        "mods/*/src/domain/**/ops/**/types.ts",
        "mods/*/src/domain/**/ops/**/index.ts",
        "mods/*/src/domain/**/ops/**/rules/**/*.ts",
        "mods/*/src/domain/**/ops/**/strategies/**/*.ts"
      ]
    }
  ]
}
