{
  "id": "prohibit_runtime_calls_to_runvalidated",
  "title": "Prohibit Runtime Calls To runValidated",
  "ownerTool": "grit-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "runtime recipe steps and domain strategies",
  "forbids": "runtime layers calling runValidated",
  "why": "Validation belongs to authoring/compile time, not runtime op execution.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "grit-check"
  ],
  "remediate": null,
  "message": "Runtime layers must not call runValidated.",
  "exceptionPath": "none",
  "patternName": "prohibit_runtime_calls_to_runvalidated",
  "hookCheck": true,
  "scanRoots": [
    "mods/mod-swooper-maps/src/recipes",
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/*/src/recipes/**/stages/**/steps/**/*.ts",
        "mods/*/src/domain/**/ops/**/strategies/**/*.ts"
      ]
    }
  ]
}
