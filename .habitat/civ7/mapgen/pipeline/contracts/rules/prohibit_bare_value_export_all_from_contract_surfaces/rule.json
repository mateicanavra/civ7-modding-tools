{
  "schemaVersion": 2,
  "id": "prohibit_bare_value_export_all_from_contract_surfaces",
  "title": "Prohibit Bare Value Export All From Contract Surfaces",
  "placement": {
    "niche": "civ7/mapgen/pipeline/contracts",
    "blueprint": "_self",
    "category": "contract"
  },
  "operation": {
    "kind": "check"
  },
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "forbids": "bare value export * in domain contract files or recipe step config modules; export type * is allowed",
  "why": "Domain contracts and recipe StepContract config modules should publish named values; type-star exports remain safe type-only API aggregation.",
