{
  "id": "docs-site-links",
  "ownerTool": "command-check",
  "ownerProject": "civ7-docs",
  "lane": "enforced",
  "scope": "apps/docs/**/*.mdx and apps/docs/docs.json",
  "forbids": "broken Mintlify page links in the docs site",
  "why": "Docs link integrity is docs-site authority, not an app-local loose script.",
  "detect": ["bun", ".habitat/docs/site/_self/check/docs-site-links/docs-site-links.check.ts"],
  "remediate": "Repair docs links or generated site navigation inputs under apps/docs.",
  "message": "Docs site link validation failed.",
  "exceptionPath": "none",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": ["apps/docs/**/*.mdx", "apps/docs/docs.json", "apps/docs/public/**"]
    },
    {
      "kind": "project-owner"
    }
  ]
}
