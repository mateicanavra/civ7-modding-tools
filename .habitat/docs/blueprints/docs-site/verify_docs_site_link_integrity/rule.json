{
  "schemaVersion": 1,
  "id": "verify_docs_site_link_integrity",
  "title": "Verify Docs Site Link Integrity",
  "placement": {
    "niche": "docs",
    "blueprint": "docs-site",
    "category": "quality",
    "artifactKind": "check"
  },
  "ownerProject": "civ7-docs",
  "lane": "enforced",
  "forbids": "broken Mintlify page links in the docs site",
  "why": "Docs link integrity is docs-site authority, not an app-local loose script.",
  "remediate": "Repair docs links or generated site navigation inputs under apps/docs.",
  "message": "Docs site link validation failed.",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": ["apps/docs/**/*.mdx", "apps/docs/docs.json", "apps/docs/public/**"]
    },
    {
      "kind": "project-owner"
    }
  ],
  "artifacts": {
    "baseline": ".habitat/docs/blueprints/docs-site/verify_docs_site_link_integrity/baseline.json"
  },
  "runner": {
    "name": "habitat",
    "mode": "script",
    "runtime": "bun",
    "files": {
      "script": ".habitat/docs/blueprints/docs-site/verify_docs_site_link_integrity/check.ts"
    }
  }
}
