{
  "id": "domain-engine-imports",
  "ownerTool": "pattern-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/src/domain/**/ops/**/*.ts",
  "forbids": "domain ops importing engine runtime entrypoints as values",
  "why": "Domain ops stay portable domain logic; engine runtime entrypoints belong behind approved domain/runtime surfaces.",
  "detect": ["habitat", "check", "--tool", "pattern-check"],
  "remediate": null,
  "message": "Do not import engine runtime entrypoints from domain ops.",
  "exceptionPath": "none",
  "patternName": "domain_engine_imports",
  "hookCheck": true,
  "scanRoots": [
    "packages",
    "apps/mapgen-studio/src",
    "mods/mod-swooper-maps/src/recipes",
    "mods/mod-swooper-maps/src/maps",
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": ["mods/mod-swooper-maps/src/domain/**/ops/**/*.ts"]
    }
  ]
}
