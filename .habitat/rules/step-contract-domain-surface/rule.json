{
  "id": "step-contract-domain-surface",
  "ownerTool": "pattern-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/*/src/recipes/**/stages/**/steps/**/{contract.ts,*.contract.ts}",
  "forbids": "step contracts deep-importing domain internals or runtime ops",
  "why": "Step contracts bind to domain contracts, not runtime implementation surfaces.",
  "detect": ["habitat", "check", "--tool", "pattern-check"],
  "remediate": null,
  "message": "Step contracts must import only from @mapgen/domain/<domain>.",
  "exceptionPath": "none",
  "patternName": "step_contract_domain_surface",
  "hookCheck": true,
  "scanRoots": [
    "packages",
    "apps/mapgen-studio/src",
    "mods/mod-swooper-maps/src/recipes",
    "mods/mod-swooper-maps/src/maps",
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/*/src/recipes/**/stages/**/steps/**/contract.ts",
        "mods/*/src/recipes/**/stages/**/steps/**/*.contract.ts"
      ]
    }
  ]
}
