{
  "id": "stage-contract-dependencies",
  "ownerTool": "pattern-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/src/recipes/standard/stages/**/{contract.ts,*.contract.ts}",
  "forbids": "string literal dependency keys in standard recipe stage step contracts",
  "why": "Step contracts compose typed dependency/effect tags and artifact contracts; string literals drift from the owning surfaces.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "pattern-check"
  ],
  "remediate": null,
  "message": "Use typed dependency tag constants or artifact contract references instead of string literal dependency keys.",
  "exceptionPath": "none",
  "patternName": "stage_contract_dependencies",
  "hookCheck": true,
  "scanRoots": [
    "packages",
    "apps/mapgen-studio/src",
    "mods/mod-swooper-maps/src/recipes",
    "mods/mod-swooper-maps/src/maps",
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/mod-swooper-maps/src/recipes/standard/stages/**/contract.ts",
        "mods/mod-swooper-maps/src/recipes/standard/stages/**/*.contract.ts"
      ]
    }
  ]
}
