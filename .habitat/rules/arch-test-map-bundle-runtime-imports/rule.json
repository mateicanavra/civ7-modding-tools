{
  "id": "arch-test-map-bundle-runtime-imports",
  "ownerTool": "target-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/mod/** build outputs",
  "forbids": "map bundles missing embedded workspace packages, TextEncoder bootstrap, or river markers",
  "why": "Civ7 loads bundles as self-contained scripts; missing embeds fail only in-game. Requires a built tree.",
  "detect": [
    "target-check",
    "run",
    "mod-swooper-maps:test:architecture-map-bundle-runtime-imports",
    "--outputStyle=static"
  ],
  "remediate": "Run owning workspace target: mod-swooper-maps:build",
  "message": "Rebuild mod-swooper-maps; if it persists, the bundling config regressed.",
  "exceptionPath": "none",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "mods/mod-swooper-maps/mod/**"
      ]
    }
  ],
  "graphTarget": {
    "project": "mod-swooper-maps",
    "target": "test:architecture-map-bundle-runtime-imports"
  }
}
