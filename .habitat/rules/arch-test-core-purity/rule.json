{
  "id": "arch-test-core-purity",
  "ownerTool": "target-check",
  "ownerProject": "@swooper/mapgen-core",
  "lane": "enforced",
  "scope": "packages/mapgen-core prod code",
  "forbids": "Civ7 runtime references in mapgen-core production code",
  "why": "mapgen-core is a pure TS engine; runtime coupling belongs to the adapter.",
  "detect": [
    "target-check",
    "run",
    "@swooper/mapgen-core:test:architecture-core-purity",
    "--outputStyle=static"
  ],
  "remediate": null,
  "message": "Remove the Civ7 runtime reference; use adapter types only.",
  "exceptionPath": "none",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": ["packages/mapgen-core"]
    }
  ],
  "graphTarget": {
    "project": "@swooper/mapgen-core",
    "target": "test:architecture-core-purity"
  }
}
