{
  "id": "op-calls-op",
  "ownerTool": "pattern-check",
  "ownerProject": "mod-swooper-maps",
  "lane": "enforced",
  "scope": "mods/mod-swooper-maps/src/domain/**/ops/*/index.ts",
  "forbids": "domain op runtime entrypoints importing sibling op runtimes or the domain ops barrel",
  "why": "Domain ops stay atomic; step and stage composition owns cross-op orchestration.",
  "detect": ["habitat", "check", "--tool", "pattern-check"],
  "remediate": null,
  "message": "Move op composition into the owning step/stage or public domain surface.",
  "exceptionPath": "none",
  "patternName": "op_calls_op",
  "hookCheck": true,
  "scanRoots": [
    "packages",
    "apps/mapgen-studio/src",
    "mods/mod-swooper-maps/src/recipes",
    "mods/mod-swooper-maps/src/maps",
    "mods/mod-swooper-maps/src/domain"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": ["mods/mod-swooper-maps/src/domain/**/ops/*/index.ts"]
    }
  ]
}
