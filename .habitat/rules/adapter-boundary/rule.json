{
  "id": "adapter-boundary",
  "ownerTool": "command-check",
  "ownerProject": "@internal/habitat-harness",
  "lane": "enforced",
  "scope": "packages/**",
  "forbids": "/base-standard/ imports outside packages/civ7-adapter",
  "why": "The adapter is the sole owner of Civ7 engine surfaces; leaks make engine coupling untrackable.",
  "detect": [
    "./scripts/lint/lint-adapter-boundary.sh"
  ],
  "remediate": null,
  "message": "Move the /base-standard/ import into @civ7/adapter, or remove it from the allowlisted script debt.",
  "exceptionPath": "none",
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "packages/**"
      ]
    },
    {
      "kind": "project-owner"
    }
  ]
}
