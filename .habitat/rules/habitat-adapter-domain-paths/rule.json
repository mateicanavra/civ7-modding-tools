{
  "id": "habitat-adapter-domain-paths",
  "ownerTool": "pattern-check",
  "ownerProject": "@internal/habitat-harness",
  "lane": "enforced",
  "scope": "tools/habitat-harness/src/adapters/grit/**",
  "forbids": "product/domain scan roots hard-coded inside the pattern adapter",
  "why": "The adapter is a generic tool boundary; repo-specific scan roots are rule registry metadata.",
  "detect": [
    "habitat",
    "check",
    "--tool",
    "pattern-check"
  ],
  "remediate": null,
  "message": "Move product-specific scan roots out of the pattern adapter and into rule registry metadata.",
  "exceptionPath": "none",
  "patternName": "habitat_adapter_domain_paths",
  "hookCheck": true,
  "scanRoots": [
    "tools/habitat-harness/src/adapters/grit"
  ],
  "pathCoverage": [
    {
      "kind": "exact-path",
      "patterns": [
        "tools/habitat-harness/src/adapters/grit/**"
      ]
    },
    {
      "kind": "project-owner"
    }
  ]
}
