{
  "name": "mapgen-studio",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "nx": {
    "tags": [
      "kind:app"
    ],
    "targets": {
      "dev": {
        "executor": "nx:run-script",
        "options": {
          "script": "dev:frontend"
        },
        "dependsOn": [
          "serve-daemon"
        ],
        "cache": false,
        "continuous": true
      },
      "serve-daemon": {
        "executor": "nx:run-script",
        "options": {
          "script": "dev:server"
        },
        "dependsOn": [
          "^build",
          {
            "projects": [
              "mod-swooper-maps"
            ],
            "target": "build:studio-recipes"
          }
        ],
        "cache": false,
        "continuous": true
      },
      "build": {
        "command": "node -e \"\"",
        "cache": false,
        "outputs": [
          "{projectRoot}/dist/**"
        ],
        "dependsOn": [
          "lint"
        ]
      },
      "check": {
        "dependsOn": [
          "^build",
          {
            "projects": [
              "mod-swooper-maps"
            ],
            "target": "build:studio-recipes"
          }
        ]
      },
      "test": {
        "dependsOn": [
          "^build",
          {
            "projects": [
              "mod-swooper-maps"
            ],
            "target": "build:studio-recipes"
          }
        ]
      },
      "build:vite": {
        "dependsOn": [
          "check",
          "^build",
          {
            "projects": [
              "mod-swooper-maps"
            ],
            "target": "build:studio-recipes"
          }
        ],
        "outputs": [
          "{projectRoot}/dist/**"
        ]
      },
      "lint": {
        "dependsOn": [
          "build:vite"
        ],
        "cache": true,
        "outputs": []
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:server": "bun src/server/daemon/daemon.ts",
    "serve": "bun src/server/daemon/daemon.ts --assets-root dist",
    "gen:civ7-tables": "bun ../../scripts/mapgen-studio/generate-civ7-browser-tables.ts",
    "ensure:studio-recipe-artifacts": "node ./scripts/ensure-studio-recipe-artifacts.mjs",
    "lint": "bun ../../tools/habitat-harness/bin/dev.ts check --rule worker-bundle",
    "check": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --project mapgen-studio",
    "build": "vite build",
    "preview": "vite preview",
    "build:vite": "vite build"
  },
  "dependencies": {
    "@civ7/adapter": "workspace:*",
    "@civ7/control-orpc": "workspace:*",
    "@civ7/direct-control": "workspace:*",
    "@civ7/map-policy": "workspace:*",
    "@civ7/plugin-mods": "workspace:*",
    "@civ7/studio-server": "workspace:*",
    "@orpc/client": "1.14.6",
    "@orpc/contract": "1.14.6",
    "@orpc/server": "1.14.6",
    "@orpc/tanstack-query": "1.14.5",
    "@tanstack/react-query": "5.101.0",
    "@deck.gl/core": "^9.0.43",
    "@deck.gl/layers": "^9.0.43",
    "@deck.gl/react": "^9.0.43",
    "@fontsource/inter": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-popover": "1.1.16",
    "@radix-ui/react-scroll-area": "1.2.11",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-switch": "1.3.0",
    "@radix-ui/react-tabs": "1.1.14",
    "@radix-ui/react-tooltip": "1.2.9",
    "@standard-schema/spec": "^1.1.0",
    "@rjsf/core": "^6.2.5",
    "@rjsf/utils": "^6.2.5",
    "@rjsf/validator-ajv8": "^6.2.5",
    "@swooper/mapgen-core": "workspace:*",
    "@swooper/mapgen-viz": "workspace:*",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "effect": "3.21.3",
    "effect-orpc": "0.3.0",
    "lucide-react": "0.522.0",
    "mod-swooper-maps": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "2.0.7",
    "tailwind-merge": "latest",
    "typebox": "^1.0.80",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1"
  }
}
