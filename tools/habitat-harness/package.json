{
  "name": "@internal/habitat-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Repo-local enforcement harness: single entrypoint over all structural checks, with ratchet baselines (see docs/projects/habitat-harness/FRAME.md)",
  "habitatHierarchyV1IntegrationNote": "Some Grit validation inputs still reference flat .habitat/patterns paths; rewire these through the accepted authority resolver in a follow-up Toolkit integration slice.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "habitat": "./bin/run.js"
  },
  "generators": "./generators.json",
  "files": [
    "bin",
    "dist",
    "generators.json",
    "oclif.manifest.json",
    "src"
  ],
  "nx": {
    "tags": [
      "kind:tooling"
    ],
    "targets": {
      "build:tsc": {
        "dependsOn": [
          "clean:dist"
        ],
        "cache": true,
        "outputs": [
          "{projectRoot}/dist/**"
        ]
      },
      "build:manifest": {
        "dependsOn": [
          "build:tsc"
        ],
        "cache": true,
        "outputs": [
          "{projectRoot}/oclif.manifest.json"
        ]
      },
      "build:bin-mode": {
        "dependsOn": [
          "build:manifest"
        ],
        "cache": false,
        "outputs": []
      },
      "build": {
        "command": "node -e \"\"",
        "cache": false,
        "outputs": [
          "{projectRoot}/dist/**",
          "{projectRoot}/oclif.manifest.json"
        ],
        "dependsOn": [
          "build:bin-mode"
        ]
      },
      "validate:boundary-taxonomy": {
        "command": "bun run --cwd tools/habitat-harness validate:boundary-taxonomy",
        "cache": true,
        "inputs": [
          "{workspaceRoot}/.habitat/habitat/toolkit/boundaries/boundary-taxonomy/validate-boundary-taxonomy.ts",
          "{workspaceRoot}/eslint.boundaries.config.mjs",
          "{workspaceRoot}/nx.json",
          "{workspaceRoot}/package.json",
          "{workspaceRoot}/bun.lock",
          "{workspaceRoot}/docs/projects/habitat-harness/taxonomy.md",
          "{workspaceRoot}/apps/**/package.json",
          "{workspaceRoot}/mods/**/package.json",
          "{workspaceRoot}/packages/**/package.json",
          "{workspaceRoot}/tools/**/package.json",
          "{workspaceRoot}/apps/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
          "{workspaceRoot}/mods/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
          "{workspaceRoot}/packages/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
          "{workspaceRoot}/scripts/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
          "{workspaceRoot}/tools/**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}",
          "!{workspaceRoot}/**/dist/**",
          "!{workspaceRoot}/**/types/**",
          "!{workspaceRoot}/**/mod/**",
          "!{workspaceRoot}/**/example-generated-mod/**"
        ],
        "metadata": {
          "description": "validates Habitat boundary taxonomy against manifests, Nx metadata, boundary config, and graph edges"
        }
      },
      "validate:grit-patterns": {
        "command": "bun run --cwd tools/habitat-harness validate:grit-patterns",
        "cache": true,
        "inputs": [
          "{workspaceRoot}/.grit/grit.yaml",
          "{workspaceRoot}/.habitat/patterns/**/*.md",
          "{workspaceRoot}/.habitat/habitat/toolkit/capabilities/legacy-source-check/**/*.mjs",
          "{workspaceRoot}/package.json",
          "{workspaceRoot}/bun.lock",
          "{workspaceRoot}/tools/habitat-harness/package.json"
        ],
        "metadata": {
          "description": "validates checked-in Habitat Grit pattern fixtures through native grit patterns test"
        }
      },
      "validate:service-module-shape": {
        "command": "bun run --cwd tools/habitat-harness validate:service-module-shape",
        "cache": true,
        "inputs": [
          "{workspaceRoot}/.habitat/habitat/toolkit/structure/service-module-shape/validate-service-module-shape.ts",
          "{workspaceRoot}/.habitat/habitat/toolkit/capabilities/legacy-source-check/**/*.mjs",
          "{workspaceRoot}/tools/habitat-harness/src/service/modules/**",
          "{workspaceRoot}/tools/habitat-harness/src/service/model/**",
          "{workspaceRoot}/tools/habitat-harness/package.json"
        ],
        "metadata": {
          "description": "validates collect-style Habitat service module and service-model file-kind topology"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun run bin/dev.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project habitat-harness --testTimeout=30000",
    "validate:cli-smoke": "bun run ../../.habitat/habitat/toolkit/capabilities/cli-smoke/validate-cli-smoke.ts",
    "validate:boundary-taxonomy": "env -u FORCE_COLOR bun run ../../.habitat/habitat/toolkit/boundaries/boundary-taxonomy/validate-boundary-taxonomy.ts",
    "validate:service-module-shape": "env -u FORCE_COLOR bun run ../../.habitat/habitat/toolkit/structure/service-module-shape/validate-service-module-shape.ts",
    "validate:grit-patterns": "env -u FORCE_COLOR bun run --cwd ../.. grit patterns test",
    "generate:schemas": "bun run ../../.habitat/habitat/toolkit/contracts/generator-schemas/write-generator-schemas.ts",
    "clean": "rimraf dist oclif.manifest.json",
    "clean:dist": "rimraf dist oclif.manifest.json",
    "build:tsc": "tsc -p tsconfig.json",
    "build:manifest": "oclif manifest",
    "build:bin-mode": "chmod +x bin/run.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli/*": {
      "bun": "./src/cli/*.ts",
      "types": "./src/cli/*.ts",
      "import": "./dist/cli/*.js",
      "default": "./dist/cli/*.js"
    },
    "./service/*": {
      "bun": "./src/service/*.ts",
      "types": "./src/service/*.ts",
      "import": "./dist/service/*.js",
      "default": "./dist/service/*.js"
    },
    "./providers/*": {
      "bun": "./src/providers/*.ts",
      "types": "./src/providers/*.ts",
      "import": "./dist/providers/*.js",
      "default": "./dist/providers/*.js"
    },
    "./resources/*": {
      "bun": "./src/resources/*.ts",
      "types": "./src/resources/*.ts",
      "import": "./dist/resources/*.js",
      "default": "./dist/resources/*.js"
    },
    "./runtime/*": {
      "bun": "./src/runtime/*.ts",
      "types": "./src/runtime/*.ts",
      "import": "./dist/runtime/*.js",
      "default": "./dist/runtime/*.js"
    },
    "./generators/scaffold/model": {
      "bun": "./src/generators/scaffold/model/index.ts",
      "types": "./src/generators/scaffold/model/index.ts",
      "import": "./dist/generators/scaffold/model/index.js",
      "default": "./dist/generators/scaffold/model/index.js"
    },
    "./validation/*": {
      "bun": "./src/validation/*.ts",
      "types": "./src/validation/*.ts",
      "import": "./dist/validation/*.js",
      "default": "./dist/validation/*.js"
    },
    "./nx-plugin": {
      "bun": "./src/nx-plugin.ts",
      "types": "./src/nx-plugin.ts",
      "import": "./dist/nx-plugin.js",
      "default": "./dist/nx-plugin.js"
    }
  },
  "dependencies": {
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.107.0",
    "@nx/devkit": "22.7.5",
    "@oclif/core": "^4.11.4",
    "@oclif/plugin-help": "^6.2.50",
    "@orpc/client": "1.14.6",
    "@orpc/contract": "1.14.6",
    "@orpc/server": "1.14.6",
    "@orpc/shared": "^1.14.4",
    "@standard-schema/spec": "^1.1.0",
    "effect": "3.21.3",
    "effect-orpc": "0.5.0",
    "typebox": "^1.0.80"
  },
  "oclif": {
    "bin": "habitat",
    "dirname": "habitat-harness",
    "commands": "./dist/cli/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {}
  }
}
