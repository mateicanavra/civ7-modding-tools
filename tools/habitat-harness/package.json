{
  "name": "@internal/habitat-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Repo-local enforcement harness: single entrypoint over all structural checks, with ratchet baselines (see docs/projects/habitat-harness/FRAME.md)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "habitat": "./bin/run.js"
  },
  "generators": "./generators.json",
  "migrations": "./migrations.json",
  "files": [
    "bin",
    "dist",
    "generators.json",
    "migrations.json",
    "oclif.manifest.json",
    "src/generators",
    "src/migrations",
    "src/plugin.js",
    "src/rules/rules.json",
    "baselines"
  ],
  "nx": {
    "tags": [
      "kind:tooling"
    ]
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && oclif manifest && chmod +x bin/run.js",
    "dev": "bun run bin/dev.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project habitat-harness",
    "clean": "rimraf dist oclif.manifest.json"
  },
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.js",
    "./rules": "./src/rules/rules.json"
  },
  "dependencies": {
    "@nx/devkit": "22.7.5",
    "@oclif/core": "^4.8.0",
    "@oclif/plugin-help": "^6.2.37"
  },
  "oclif": {
    "bin": "habitat",
    "dirname": "habitat-harness",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {}
  }
}
