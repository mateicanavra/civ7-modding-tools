{
  "name": "@internal/habitat-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Repo-local enforcement harness: single entrypoint over all structural checks, with ratchet baselines (see docs/projects/habitat-harness/FRAME.md)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "habitat": "./bin/run.js"
  },
  "generators": "./generators.json",
  "files": [
    "bin",
    "dist",
    "generators.json",
    "oclif.manifest.json",
    "src/generators",
    "src/lib/artifact-paths.ts",
    "src/lib/paths.ts",
    "src/lib/workspace-graph",
    "src/lib/workspace-graph-contract.ts",
    "src/plugin",
    "src/plugin.ts",
    "src/rules/registry"
  ],
  "nx": {
    "tags": [
      "kind:tooling"
    ],
    "targets": {
      "build:tsc": {
        "dependsOn": [
          "clean:dist"
        ],
        "cache": true,
        "outputs": [
          "{projectRoot}/dist/**"
        ]
      },
      "build:manifest": {
        "dependsOn": [
          "build:tsc"
        ],
        "cache": true,
        "outputs": [
          "{projectRoot}/oclif.manifest.json"
        ]
      },
      "build:bin-mode": {
        "dependsOn": [
          "build:manifest"
        ],
        "cache": false,
        "outputs": []
      },
      "build": {
        "command": "node -e \"\"",
        "cache": false,
        "outputs": [
          "{projectRoot}/dist/**",
          "{projectRoot}/oclif.manifest.json"
        ],
        "dependsOn": [
          "build:bin-mode"
        ]
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun run bin/dev.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --project habitat-harness --testTimeout=30000",
    "validate:cli-smoke": "bun run scripts/validate-cli-smoke.ts",
    "validate:grit-patterns": "bun run --cwd ../.. grit patterns test --json >/dev/null",
    "generate:schemas": "bun run scripts/write-generator-schemas.ts",
    "clean": "rimraf dist oclif.manifest.json",
    "clean:dist": "rimraf dist oclif.manifest.json",
    "build:tsc": "tsc -p tsconfig.json",
    "build:manifest": "oclif manifest",
    "build:bin-mode": "chmod +x bin/run.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./plugin": "./src/plugin.ts"
  },
  "dependencies": {
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.107.0",
    "@nx/devkit": "22.7.5",
    "@oclif/core": "^4.11.4",
    "@oclif/plugin-help": "^6.2.50",
    "@orpc/client": "1.14.6",
    "@orpc/contract": "1.14.6",
    "@orpc/server": "1.14.6",
    "@orpc/shared": "^1.14.4",
    "@standard-schema/spec": "^1.1.0",
    "effect": "3.21.3",
    "effect-orpc": "0.5.0",
    "typebox": "^1.0.80"
  },
  "oclif": {
    "bin": "habitat",
    "dirname": "habitat-harness",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {}
  }
}
