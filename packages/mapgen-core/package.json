{
  "name": "@swooper/mapgen-core",
  "version": "0.1.0",
  "description": "Pure TypeScript domain library for map generation algorithms",
  "keywords": [
    "civ7",
    "civilization",
    "modding",
    "mapgen",
    "voronoi",
    "tectonics"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./polyfills/text-encoder": {
      "types": "./dist/polyfills/text-encoder.d.ts",
      "import": "./dist/polyfills/text-encoder.js"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js"
    },
    "./authoring": {
      "types": "./dist/authoring/index.d.ts",
      "import": "./dist/authoring/index.js"
    },
    "./authoring/recipe-dag": {
      "types": "./dist/authoring/recipe-dag.d.ts",
      "import": "./dist/authoring/recipe-dag.js"
    },
    "./authoring/contracts": {
      "types": "./dist/authoring/contracts.d.ts",
      "import": "./dist/authoring/contracts.js"
    },
    "./compiler/normalize": {
      "types": "./dist/compiler/normalize.d.ts",
      "import": "./dist/compiler/normalize.js"
    },
    "./compiler/recipe-compile": {
      "types": "./dist/compiler/recipe-compile.d.ts",
      "import": "./dist/compiler/recipe-compile.js"
    },
    "./trace": {
      "types": "./dist/trace/index.d.ts",
      "import": "./dist/trace/index.js"
    },
    "./lib/math": {
      "types": "./dist/lib/math/index.d.ts",
      "import": "./dist/lib/math/index.js"
    },
    "./lib/grid": {
      "types": "./dist/lib/grid/index.d.ts",
      "import": "./dist/lib/grid/index.js"
    },
    "./lib/rng": {
      "types": "./dist/lib/rng/index.d.ts",
      "import": "./dist/lib/rng/index.js"
    },
    "./lib/noise": {
      "types": "./dist/lib/noise/index.d.ts",
      "import": "./dist/lib/noise/index.js"
    },
    "./lib/mesh": {
      "types": "./dist/lib/mesh/index.d.ts",
      "import": "./dist/lib/mesh/index.js"
    },
    "./lib/collections": {
      "types": "./dist/lib/collections/index.d.ts",
      "import": "./dist/lib/collections/index.js"
    },
    "./lib/plates": {
      "types": "./dist/lib/plates/index.d.ts",
      "import": "./dist/lib/plates/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "check:test": "tsc -p test/tsconfig.json --noEmit",
    "check:tools": "tsc -p tsconfig.tsup.json --noEmit",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civ7/adapter": "workspace:*",
    "@civ7/types": "workspace:*",
    "@swooper/mapgen-viz": "workspace:*",
    "d3-delaunay": "^6.0.4",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@civ7/map-policy": "workspace:*",
    "@types/d3-delaunay": "^6.0.4"
  }
}
