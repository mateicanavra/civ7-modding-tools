{
  "name": "@civ7/plugin-files",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun-source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./generated-file-plan": {
      "types": "./dist/generated-file-plan.d.ts",
      "bun-source": "./src/generated-file-plan.ts",
      "import": "./dist/generated-file-plan.js",
      "require": "./dist/generated-file-plan.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/generated-file-plan.ts --format esm,cjs --dts",
    "check:test": "tsc -p test/tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "dev": "tsup src/index.ts src/generated-file-plan.ts --format esm,cjs --dts --watch",
    "test": "vitest run --project plugin-files",
    "typecheck": "tsc -p tsconfig.json --noEmit --composite false --incremental false"
  },
  "dependencies": {
    "@civ7/config": "workspace:*"
  },
  "engines": {
    "node": "22.22.0"
  }
}
