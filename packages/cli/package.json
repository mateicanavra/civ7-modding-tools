{
  "name": "@mateicanavra/civ7-cli",
  "version": "0.1.0",
  "nx": {
    "tags": [
      "kind:app"
    ],
    "targets": {
      "build:tsc": {
        "dependsOn": [
          "clean:dist"
        ],
        "cache": true,
        "outputs": [
          "{projectRoot}/dist/**"
        ]
      },
      "build:manifest": {
        "dependsOn": [
          "build:tsc"
        ],
        "cache": true,
        "outputs": [
          "{projectRoot}/oclif.manifest.json"
        ]
      },
      "build:bin-mode": {
        "dependsOn": [
          "build:manifest"
        ],
        "cache": false,
        "outputs": []
      },
      "build": {
        "command": "node -e \"\"",
        "cache": false,
        "outputs": [
          "{projectRoot}/dist/**",
          "{projectRoot}/oclif.manifest.json"
        ],
        "dependsOn": [
          "build:bin-mode"
        ]
      },
      "test:play": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": []
      },
      "link:global": {
        "dependsOn": [
          "build"
        ],
        "cache": false,
        "outputs": []
      },
      "unlink:global": {
        "cache": false,
        "outputs": []
      },
      "readme": {
        "dependsOn": [
          "build"
        ],
        "cache": false,
        "outputs": [
          "{projectRoot}/README.md"
        ]
      },
      "pack:prepare": {
        "command": "node -e \"\"",
        "cache": false,
        "outputs": [],
        "dependsOn": [
          "build",
          "readme"
        ]
      },
      "version:readme": {
        "dependsOn": [
          "readme"
        ],
        "cache": false,
        "outputs": []
      },
      "data:zip:default": {
        "dependsOn": [
          "build"
        ],
        "cache": false,
        "outputs": []
      },
      "data:unzip:default": {
        "dependsOn": [
          "data:zip:default"
        ],
        "cache": false,
        "outputs": []
      },
      "mod:git:import": {
        "dependsOn": [
          "build"
        ],
        "cache": false,
        "outputs": []
      },
      "publish:npm": {
        "dependsOn": [
          "build",
          "lint",
          "test",
          "check"
        ],
        "cache": false,
        "outputs": []
      }
    }
  },
  "description": "CLI for managing Civilization VII modding resources.",
  "author": "Your Name",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "civ7": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -b --force",
    "dev": "bun run bin/dev.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "vitest run --project cli",
    "link:global": "bun link",
    "unlink:global": "bun unlink",
    "prepublishOnly": "node -e \"\"",
    "publish": "bun publish",
    "prepack": "node -e \"\"",
    "pack": "bun pm pack",
    "postpack": "rimraf oclif.manifest.json",
    "version": "node -e \"\"",
    "clean:dist": "rimraf dist",
    "build:tsc": "tsc -b --force",
    "build:manifest": "oclif manifest",
    "build:bin-mode": "chmod +x bin/run.js",
    "test:play": "vitest run --project cli game.play.end-turn.test.ts game.play.population-placement.test.ts game.play.attribute-tradition.test.ts game.play.town-focus.test.ts game.play.unit-target.test.ts game.play.progression-read.test.ts game.play.tactical-read.test.ts game.play.watch.test.ts game.play.topics.test.ts game.play.promotion-readiness.test.ts game.play.rehydrate.test.ts game.play.settlement-recommendations.test.ts game/play/ready-city.test.ts game/play/unit-move-preview.test.ts game/play/ready-unit.test.ts game/play/notification/queue.test.ts game/play/notification/dismiss-queue.test.ts game/play/notification/dismiss.test.ts game/play/notification/hud.test.ts game/play/priorities.test.ts game/play/semantic-envelope.test.ts game.play.first-meet.test.ts game.play.operation-wrappers.test.ts game.play.technology.test.ts game.play.culture.test.ts game.play.narrative.test.ts game.play.diplomacy-response.test.ts game.play.production.test.ts game.play.celebration-government.test.ts",
    "readme": "oclif readme",
    "pack:prepare": "node -e \"\"",
    "version:readme": "git add README.md",
    "data:zip:default": "node bin/run.js data zip default",
    "data:unzip:default": "node bin/run.js data unzip default",
    "mod:git:import": "node bin/run.js mod git import",
    "publish:npm": "bun publish --access public"
  },
  "dependencies": {
    "@civ7/config": "workspace:*",
    "@civ7/control-orpc": "workspace:*",
    "@civ7/direct-control": "workspace:*",
    "@civ7/plugin-files": "workspace:*",
    "@civ7/plugin-git": "workspace:*",
    "@civ7/plugin-graph": "workspace:*",
    "@civ7/plugin-mods": "workspace:*",
    "@oclif/core": "^4.11.4",
    "@oclif/plugin-help": "^6.2.50",
    "effect": "3.21.3",
    "tslib": "^2.8.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "public"
  },
  "oclif": {
    "bin": "civ7",
    "dirname": "cli",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "hooks": {
      "prerun": "./dist/hooks/prerun/promptMissingArgs.js"
    },
    "topics": {
      "data": {
        "description": "Work with Civilization VII data: crawl XML resources, explore relationships, zip outputs."
      },
      "docs": {
        "description": "Serve the project documentation site (Mintlify or Docsify) with optional syncing."
      },
      "git": {
        "description": "Git utilities"
      },
      "git:subtree": {
        "description": "Configure remotes, import repos, pull, push, setup and view status via git subtree"
      },
      "game": {
        "description": "Operate a running Civilization VII session through local tooling"
      },
      "game:local-data": {
        "description": "Inspect local Civ7 SQLite, save, and log evidence"
      },
      "game:map": {
        "description": "Read current world, plot, grid, start, and visibility map state"
      },
      "game:play": {
        "description": "Turn-by-turn live-play shortcuts over direct-control"
      },
      "game:play:screen": {
        "description": "Inspect and dismiss App UI display-queue screens (cinematic moments)"
      },
      "mod": {
        "description": "Manage Civilization VII mods"
      },
      "mod:git": {
        "description": "Configure and sync mod repositories via git subtree (setup, import, pull, push, status, list, clear, remove, update)"
      },
      "mod:manage": {
        "description": "Manage local mod folders (list, deploy)"
      }
    }
  },
  "engines": {
    "node": "22.22.0"
  }
}
