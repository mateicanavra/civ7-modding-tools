{
  "name": "@civ7/studio-server",
  "version": "0.1.0",
  "private": true,
  "description": "MapGen Studio server: oRPC contract-first API surface (Effect + Bun) for the Civ7 direct-control studio endpoints",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun-source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./contract": {
      "types": "./dist/contract/index.d.ts",
      "bun-source": "./src/contract/index.ts",
      "import": "./dist/contract/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@civ7/control-orpc": "workspace:*",
    "@civ7/direct-control": "workspace:*",
    "@civ7/studio-contract": "workspace:*",
    "@civ7/studio-run-workspace": "workspace:*",
    "@orpc/client": "1.14.6",
    "@orpc/contract": "1.14.6",
    "@orpc/server": "1.14.6",
    "@orpc/tanstack-query": "1.14.5",
    "@standard-schema/spec": "^1.1.0",
    "effect": "3.21.3",
    "effect-orpc": "0.3.0",
    "typebox": "^1.0.80"
  },
  "engines": {
    "node": "22.22.0"
  }
}
