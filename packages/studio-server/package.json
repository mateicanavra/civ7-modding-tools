{
  "name": "@civ7/studio-server",
  "version": "0.1.0",
  "description": "MapGen Studio server: oRPC contract-first API surface (Effect + Bun) for the Civ7 direct-control studio endpoints",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contract": {
      "types": "./dist/contract/index.d.ts",
      "import": "./dist/contract/index.js"
    },
    "./live-game": {
      "types": "./dist/liveGame/model.d.ts",
      "import": "./dist/liveGame/model.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ./vitest.config.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@civ7/control-orpc": "workspace:*",
    "@civ7/direct-control": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "typebox": "^1.0.80",
    "@orpc/client": "1.14.5",
    "@orpc/contract": "1.14.5",
    "@orpc/server": "1.14.5",
    "@orpc/tanstack-query": "1.14.5",
    "effect": "3.21.3",
    "effect-orpc": "0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
