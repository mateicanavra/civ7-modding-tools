{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "control-orpc",
  "tags": ["kind:control"],
  "targets": {
    "build": {
      "command": "node scripts/build.mjs",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist/**", "{projectRoot}/tsconfig.tsbuildinfo"],
      "options": {
        "cwd": "packages/civ7-control-orpc"
      }
    },
    "typecheck": {
      "command": "tsc -p tsconfig.json --noEmit --composite false --incremental false",
      "cache": true,
      "outputs": [],
      "options": {
        "cwd": "packages/civ7-control-orpc"
      }
    },
    "check": {
      "executor": "nx:noop",
      "cache": false,
      "outputs": []
    }
  }
}
