{
  "name": "@mateicanavra/civ7-sdk",
  "version": "0.0.0",
  "private": false,
  "nx": {
    "tags": [
      "kind:sdk"
    ],
    "targets": {
      "publish:npm": {
        "dependsOn": [
          "build",
          "lint",
          "test",
          "check"
        ],
        "cache": false,
        "outputs": []
      }
    }
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mapgen": {
      "types": "./dist/mapgen/index.d.ts",
      "import": "./dist/mapgen/index.js",
      "require": "./dist/mapgen/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/mapgen/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/mapgen/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run --project sdk",
    "lint": "biome check .",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "node -e \"\"",
    "publish:npm": "bun publish --access public"
  },
  "dependencies": {
    "@civ7/adapter": "workspace:*",
    "@swooper/mapgen-core": "workspace:*",
    "jstoxml": "^7.0.1",
    "lodash-es": "^4.17.23"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.23",
    "@types/jstoxml": "^5.0.0",
    "@civ7/types": "workspace:*"
  },
  "engines": {
    "node": "22.22.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "public"
  }
}
