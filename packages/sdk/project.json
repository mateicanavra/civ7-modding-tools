{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "civ7-sdk",
  "tags": ["kind:sdk"],
  "targets": {
    "check": {
      "executor": "nx:noop",
      "cache": false,
      "outputs": []
    },
    "publish:npm": {
      "command": "bun publish --access public",
      "dependsOn": [
        "build",
        "test",
        "check",
        {
          "projects": ["habitat"],
          "target": "check:hygiene"
        }
      ],
      "cache": false,
      "outputs": [],
      "options": {
        "cwd": "packages/sdk"
      }
    }
  }
}
