{
  "name": "@civ7/studio-contract",
  "version": "0.1.0",
  "private": true,
  "description": "MapGen Studio contract: the studio-owned oRPC contract artifact (TypeBox schemas, phase unions, DTO types) implemented by @civ7/studio-server and consumed by its clients",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun-source": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@orpc/contract": "1.14.6",
    "@standard-schema/spec": "^1.1.0",
    "typebox": "^1.0.80"
  },
  "engines": {
    "node": "22.22.0"
  }
}
