{
  "name": "@swooper/mapgen-studio-ui",
  "version": "0.1.0",
  "private": true,
  "description": "MapGen Studio UI component library — the 46 design-synced components as a real package (dist + generated .d.ts + compiled stylesheet), single source for the app and the Claude Design sync.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/types/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./src/styles/theme.css",
    "./fonts.css": "./dist/fonts.css",
    "./fonts/*": "./dist/fonts/*"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.dts.json && tailwindcss -i src/styles/index.css -o dist/styles.css && node scripts/copy-fonts.mjs",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --project mapgen-studio-ui",
    "verify": "node scripts/verify.mjs",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@civ7/studio-contract": "workspace:*",
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-popover": "1.1.16",
    "@radix-ui/react-scroll-area": "1.2.11",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-switch": "1.3.0",
    "@radix-ui/react-tabs": "1.1.14",
    "@radix-ui/react-tooltip": "1.2.9",
    "@rjsf/core": "6.2.5",
    "@rjsf/utils": "6.2.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.522.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "typebox": "1.0.80"
  },
  "devDependencies": {
    "@rjsf/validator-ajv8": "6.2.5",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/react-vite": "9.1.20",
    "@tailwindcss/cli": "4.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "jsdom": "29.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "9.1.20",
    "tailwindcss": "4.3.0"
  },
  "engines": {
    "node": ">=22"
  },
  "nx": {
    "tags": [
      "kind:foundation"
    ],
    "targets": {
      "test": {
        "dependsOn": [
          "build",
          "^build"
        ]
      }
    }
  }
}
