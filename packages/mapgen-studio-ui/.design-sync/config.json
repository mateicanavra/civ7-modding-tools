{
  "pkg": "@swooper/mapgen-studio-ui",
  "globalName": "MapGenStudio",
  "projectId": "531d158d-a7f6-41cb-87a4-f0f8a5e521b0",
  "shape": "storybook",
  "storybookStatic": ".design-sync/sb-reference",
  "storybookConfigDir": ".storybook",
  "srcDir": "src",
  "tsconfig": "tsconfig.json",
  "entry": "dist/index.js",
  "cssEntry": "dist/styles.css",
  "extraFonts": ["dist/fonts.css"],
  "buildCmd": "bunx nx run mapgen-studio-ui:build",
  "readmeHeader": ".design-sync/conventions.md",
  "guidelinesGlob": "docs/*.md",
  "provider": {
    "component": "TooltipProvider",
    "props": { "delayDuration": 300 }
  },
  "overrides": {
    "Dialog": { "cardMode": "single", "viewport": "680x360" },
    "AppFooter": { "cardMode": "column" },
    "Select": { "cardMode": "single", "viewport": "420x460" },
    "DropdownMenu": { "cardMode": "single", "viewport": "420x460" },
    "Popover": { "cardMode": "single", "viewport": "460x360" },
    "Tooltip": { "cardMode": "single", "viewport": "400x240" },
    "AppHeader": { "cardMode": "column" },
    "DisclosureHeader": { "cardMode": "column" },
    "EmptyState": { "cardMode": "column" },
    "ExplorePanel": { "cardMode": "column" },
    "GameConsole": { "cardMode": "column" },
    "RecipePanel": { "cardMode": "column" },
    "StageViewTabs": { "cardMode": "column" },
    "Separator": { "cardMode": "column" },
    "Tabs": { "cardMode": "column" },
    "Textarea": { "cardMode": "column" },
    "Toaster": { "cardMode": "single", "primaryStory": "Notifications" },
    "MapConfigSaveDialog": { "cardMode": "single", "viewport": "680x460" },
    "BrowserConfigFieldTemplate": { "cardMode": "column" },
    "BrowserConfigObjectFieldTemplate": { "cardMode": "column" },
    "BrowserConfigArrayFieldTemplate": { "cardMode": "column" },
    "PipelineStage": { "cardMode": "single", "viewport": "1080x620" },
    "SchemaConfigForm": { "cardMode": "column" },
    "TagSelectWidget": { "cardMode": "column" },
    "StudioShellLayout": { "cardMode": "single", "viewport": "1280x800" }
  },
  "docsMap": {
    "Button": ".design-sync/groups/primitives.md",
    "Checkbox": ".design-sync/groups/primitives.md",
    "Dialog": ".design-sync/groups/primitives.md",
    "DropdownMenu": ".design-sync/groups/primitives.md",
    "Input": ".design-sync/groups/primitives.md",
    "Label": ".design-sync/groups/primitives.md",
    "Popover": ".design-sync/groups/primitives.md",
    "ScrollArea": ".design-sync/groups/primitives.md",
    "Select": ".design-sync/groups/primitives.md",
    "Separator": ".design-sync/groups/primitives.md",
    "Switch": ".design-sync/groups/primitives.md",
    "Tabs": ".design-sync/groups/primitives.md",
    "Textarea": ".design-sync/groups/primitives.md",
    "Tooltip": ".design-sync/groups/primitives.md",
    "Toaster": ".design-sync/groups/primitives.md",
    "FieldRow": ".design-sync/groups/primitives.md",
    "AppBrand": ".design-sync/groups/composites.md",
    "AppHeader": ".design-sync/groups/composites.md",
    "AppFooter": ".design-sync/groups/composites.md",
    "StageViewTabs": ".design-sync/groups/composites.md",
    "ViewControls": ".design-sync/groups/composites.md",
    "WaterStatsSection": ".design-sync/groups/composites.md",
    "OptionSelect": ".design-sync/groups/composites.md",
    "DisclosureHeader": ".design-sync/groups/composites.md",
    "EmptyState": ".design-sync/groups/composites.md",
    "ErrorBanner": ".design-sync/groups/composites.md",
    "MapConfigSaveDialog": ".design-sync/groups/composites.md",
    "LeftDock": ".design-sync/groups/layout.md",
    "RightDock": ".design-sync/groups/layout.md",
    "ExplorePanel": ".design-sync/groups/panels.md",
    "GameConsole": ".design-sync/groups/panels.md",
    "RecipePanel": ".design-sync/groups/panels.md",
    "TextWidget": ".design-sync/groups/forms.md",
    "TextareaWidget": ".design-sync/groups/forms.md",
    "NumberWidget": ".design-sync/groups/forms.md",
    "SelectWidget": ".design-sync/groups/forms.md",
    "CheckboxWidget": ".design-sync/groups/forms.md",
    "SwitchWidget": ".design-sync/groups/forms.md",
    "TagSelectWidget": ".design-sync/groups/forms.md",
    "BrowserConfigFieldTemplate": ".design-sync/groups/forms.md",
    "BrowserConfigObjectFieldTemplate": ".design-sync/groups/forms.md",
    "BrowserConfigArrayFieldTemplate": ".design-sync/groups/forms.md",
    "PipelineStage": ".design-sync/groups/panels.md",
    "SchemaConfigForm": ".design-sync/groups/forms.md",
    "StudioShellLayout": ".design-sync/groups/templates.md"
  }
}
