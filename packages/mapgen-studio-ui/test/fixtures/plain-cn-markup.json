  "DisclosureHeader/PanelHeaders": "<div class=\"bg-popover/95 text-foreground border border-border divide-y divide-border-subtle\" style=\"width:300px;border-radius:8px;overflow:hidden\"><button type=\"button\" aria-expanded=\"true\" aria-controls=\"disclosure-stage\" class=\"w-full flex items-center justify-between transition-colors hover:bg-accent px-3 py-2.5\"><div class=\"flex items-center gap-2 min-w-0 overflow-hidden\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-compass w-4 h-4 shrink-0 text-muted-foreground\" aria-hidden=\"true\"><path d=\"m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg><span class=\"text-[13px] font-semibold text-foreground\">Stage</span></div><div class=\"flex items-center gap-2 shrink-0\"><span class=\"text-label text-muted-foreground/70\">7</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-3.5 h-3.5 text-muted-foreground/70 transition-transform rotate-180\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></button><button type=\"button\" aria-expanded=\"false\" aria-controls=\"disclosure-step\" class=\"w-full flex items-center justify-between transition-colors hover:bg-accent px-3 py-2\"><div class=\"flex items-center gap-2 min-w-0 overflow-hidden\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-layers w-3.5 h-3.5 shrink-0 text-muted-foreground\" aria-hidden=\"true\"><path d=\"M12.83 2.