{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Strict declaration emit — the .d.ts tree the design-sync converter and
    // the `./types` export condition resolve from. Unlike the retired
    // build-inputs.sh emit (noEmitOnError:false, tolerated errors), this one
    // FAILS the build on any type error: the package owns its whole type
    // closure, so an error here is a real defect, never tolerable drift.
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist/types",
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.stories.tsx", "src/**/*.stories.ts"]
}
