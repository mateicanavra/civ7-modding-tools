{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "control-direct",
  "tags": ["kind:control"],
  "targets": {
    "build-bundle": {
      "command": "tsup --config tsup.config.ts",
      "options": {
        "cwd": "packages/civ7-direct-control"
      },
      "cache": true,
      "outputs": ["{projectRoot}/dist/**/*.js", "{projectRoot}/dist/**/*.cjs"]
    },
    "build-types": {
      "command": "rimraf --glob \"dist/**/*.d.ts\" \"dist/**/*.d.ts.map\" tsconfig.tsbuildinfo && tsc -b tsconfig.json --force --emitDeclarationOnly",
      "options": {
        "cwd": "packages/civ7-direct-control"
      },
      "dependsOn": [
        "build-bundle",
        {
          "projects": ["civ7-map-policy"],
          "target": "build"
        }
      ],
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/**/*.d.ts",
        "{projectRoot}/dist/**/*.d.ts.map",
        "{projectRoot}/tsconfig.tsbuildinfo"
      ]
    },
    "build": {
      "executor": "nx:noop",
      "dependsOn": ["build-types"],
      "cache": false,
      "outputs": []
    }
  }
}
