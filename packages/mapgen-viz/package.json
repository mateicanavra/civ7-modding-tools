{
  "name": "@swooper/mapgen-viz",
  "version": "0.1.0",
  "description": "Shared visualization contract types for MapGen (manifest/protocol/value semantics)",
  "private": true,
  "nx": {
    "tags": [
      "kind:foundation"
    ]
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": "22.22.0"
  }
}
