{
  "name": "@swooper/mapgen-viz",
  "version": "0.1.0",
  "private": true,
  "description": "Shared visualization contract types for MapGen (manifest/protocol/value semantics)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rimraf dist",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": "22.22.0"
  }
}
