{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules/**",
      "!dist/**",
      "!**/dist/**",
      "!types/**",
      "!**/types/**",
      "!mod/**",
      "!**/mod/**",
      "!.nx/**",
      "!.civ7/outputs/**",
      "!docs/_archive/**",
      "!mods/mod-swooper-maps/src/maps/generated/**",
      "!packages/civ7-types/generated/**",
      "!packages/civ7-map-policy/src/civ7-tables.gen.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
