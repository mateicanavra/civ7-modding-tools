{
  "name": "civ7-modding-tools",
  "version": "1.3.0",
  "description": "CLI tools and utilities for Civilization VII modding, including resource extraction, graph visualization, and XML analysis",
  "type": "module",
  "packageManager": "bun@1.3.7",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check && bun run lint:domain-refactor-guardrails && bun run lint:mapgen-recipe-imports && bun run lint:normalization-guardrails && bun run lint:mapgen-docs",
    "check-types": "turbo run check",
    "dev:cli": "bun run --filter @mateicanavra/civ7-cli dev",
    "dev:sdk": "bun run --filter @mateicanavra/civ7-sdk dev",
    "dev:docs": "bun run --filter @civ7/docs dev",
    "docs:project": "./scripts/docs-project.sh && bunx docsify-cli serve ./docs --port 7979",
    "dev:playground": "bun run --filter @civ7/playground dev",
    "dev:mapgen-studio": "turbo run dev --filter=mapgen-studio",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test",
    "test:architecture-cutover": "turbo run test:architecture-cutover --filter=mod-swooper-maps",
    "test:vitest": "vitest run",
    "test:ui": "vitest --ui",
    "clean": "turbo run clean",
    "publish:sdk": "bun publish --cwd packages/sdk --access public",
    "publish:cli": "bun publish --cwd packages/cli --access public",
    "publish:all": "bun run publish:sdk && bun run publish:cli",
    "link:cli": "bun run --cwd packages/cli link:global",
    "unlink:cli": "bun run --cwd packages/cli unlink:global",
    "resources:init": "bash ./scripts/civ7-resources/init-submodule.sh",
    "resources:publish": "bash ./scripts/civ7-resources/publish-submodule.sh",
    "resources:status": "bash ./scripts/civ7-resources/status.sh",
    "resources:unlock": "python3 ./scripts/civ7-resources/unlock-submodule.py",
    "setup:git-hooks": "bash ./scripts/git-hooks/setup.sh",
    "refresh:data": "bun run resources:init && bun run --filter @civ7/plugin-files build && bun run dev:cli -- data zip default && bun run dev:cli -- data unzip default",
    "mods:import": "bun run dev:cli -- mod git import",
    "test:mapgen": "turbo run test --filter=@swooper/mapgen-core",
    "verify:studio-run-in-game": "turbo run build check --filter=@civ7/direct-control --filter=@mateicanavra/civ7-sdk --filter=mod-swooper-maps --filter=mapgen-studio && turbo run test --filter=@civ7/direct-control --filter=@mateicanavra/civ7-sdk --filter=mapgen-studio && turbo run test:studio-run-in-game --filter=mod-swooper-maps && bun run openspec -- validate direct-control-new-game-setup --strict && bun run openspec -- validate studio-run-current-map-config --strict && bun run openspec -- validate studio-live-civ7-map-sync --strict && bun run openspec -- validate studio-disposable-setup-reload --strict && bun run openspec -- validate workspace-build-pipeline --strict && bun run openspec -- validate studio-run-in-game-robustness --strict",
    "verify:studio-run-in-game:live": "bun scripts/civ7-direct-control/verify-studio-run-in-game-live.ts",
    "build:mapgen": "bun run --cwd packages/mapgen-core build",
    "lint:adapter-boundary": "./scripts/lint/lint-adapter-boundary.sh",
    "lint:domain-refactor-guardrails": "./scripts/lint/lint-domain-refactor-guardrails.sh",
    "lint:mapgen-recipe-imports": "./scripts/lint/lint-mapgen-recipe-imports.sh",
    "lint:normalization-guardrails": "node scripts/lint/lint-normalization-guardrails.mjs",
    "lint:domain-refactor-guardrails:strict-core": "REFRACTOR_DOMAINS=\"foundation,morphology,hydrology,ecology,placement,narrative\" DOMAIN_REFACTOR_GUARDRAILS_PROFILE=full DOMAIN_REFACTOR_GUARDRAILS_REQUIRE_FULL=1 ./scripts/lint/lint-domain-refactor-guardrails.sh",
    "ci:architecture-strict-core": "bun run lint && bun run lint:adapter-boundary && bun run test:architecture-cutover && bun run lint:domain-refactor-guardrails && bun run check",
    "lint:adrs": "node scripts/lint/lint-doc-adrs.mjs",
    "lint:doc-ambiguity": "node scripts/lint/lint-doc-ambiguity.mjs",
    "lint:mapgen-docs": "python3 ./scripts/lint/lint-mapgen-docs.py",
    "deploy:mods": "turbo run deploy --filter='./mods/*'",
    "gt:import-worktree": "bash ./scripts/graphite-import-worktree.sh",
    "gt:import-pr": "bash ./scripts/graphite-import-pr.sh",
    "mapgen-studio:gen-civ7-tables": "bun ./scripts/mapgen-studio/generate-civ7-browser-tables.ts",
    "verify:placement-catalogs": "bun scripts/placement/verify-manual-catalogs.ts",
    "openspec": "openspec",
    "openspec:validate": "openspec validate --all --strict"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*",
    "mods/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateicanavra/civ7-modding-tools-fork.git"
  },
  "homepage": "https://github.com/mateicanavra/civ7-modding-tools-fork#readme",
  "bugs": {
    "url": "https://github.com/mateicanavra/civ7-modding-tools-fork/issues"
  },
  "author": "Matei <tools@matei.work>",
  "license": "MIT",
  "keywords": [
    "civilization-vii",
    "civ7",
    "modding",
    "tools",
    "cli",
    "xml",
    "graph-visualization",
    "typescript",
    "game-modding",
    "resource-extraction"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@fission-ai/openspec": "^1.3.1",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "turbo": "^2.7.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "typescript": "^5.9.3",
    "@types/node": "^22.14.0",
    "rimraf": "^6.1.2"
  }
}
