{
  "name": "civ7-modding-tools",
  "version": "1.3.0",
  "description": "CLI tools and utilities for Civilization VII modding, including resource extraction, graph visualization, and XML analysis",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "prepare": "husky",
    "build": "nx run-many --targets=build",
    "check": "nx run-many --targets=check",
    "docs:project": "./.habitat/docs/blueprints/docs-site/artifact/generate/generate_docs_sidebar_from_docs_tree/generate_docs_sidebar_from_docs_tree.generate.sh && bunx docsify-cli serve ./docs --port 7979",
    "restart:mapgen-studio": "bash ./scripts/restart-mapgen-studio.sh",
    "dev:mapgen-studio:restart": "bun run restart:mapgen-studio",
    "lint": "nx run-many --targets=lint",
    "test": "nx run-many --targets=test",
    "clean": "nx run-many --targets=clean",
    "resources:init": "bash ./packages/cli/scripts/resources-submodule/init-submodule.sh",
    "resources:publish": "bash ./packages/cli/scripts/resources-submodule/publish-submodule.sh",
    "resources:status": "bash ./packages/cli/scripts/resources-submodule/status.sh",
    "resources:unlock": "python3 ./packages/cli/scripts/resources-submodule/unlock-submodule.py",
    "refresh:data": "bun run resources:init && nx run civ7-cli:data:zip:default && nx run civ7-cli:data:unzip:default",
    "ci:architecture-strict-core": "REFRACTOR_DOMAINS=\"foundation,morphology,hydrology,ecology,placement,narrative\" DOMAIN_REFACTOR_GUARDRAILS_PROFILE=full DOMAIN_REFACTOR_GUARDRAILS_REQUIRE_FULL=1 bun habitat check --rule enforce_domain_refactor_boundary_profile",
    "deploy:mods": "nx run-many --targets=deploy",
    "gt:import-worktree": "bash ./scripts/graphite-import-worktree.sh",
    "gt:import-pr": "bash ./scripts/graphite-import-pr.sh",
    "openspec": "openspec",
    "openspec:validate": "openspec validate --all --strict",
    "biome:format": "biome format --write .",
    "biome:check": "biome check .",
    "biome:ci": "biome ci .",
    "habitat": "bun tools/habitat/bin/dev.ts",
    "ci": "nx run-many --targets=build,check,lint,test,habitat:check",
    "verify": "nx run-many --targets=verify"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*",
    "mods/*",
    "tools/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateicanavra/civ7-modding-tools-fork.git"
  },
  "homepage": "https://github.com/mateicanavra/civ7-modding-tools-fork#readme",
  "bugs": {
    "url": "https://github.com/mateicanavra/civ7-modding-tools-fork/issues"
  },
  "author": "Matei <tools@matei.work>",
  "license": "MIT",
  "keywords": [
    "civilization-vii",
    "civ7",
    "modding",
    "tools",
    "cli",
    "xml",
    "graph-visualization",
    "typescript",
    "game-modding",
    "resource-extraction"
  ],
  "engines": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@fission-ai/openspec": "^1.3.1",
    "@getgrit/cli": "0.1.0-alpha.1743007075",
    "@nx/eslint-plugin": "22.7.5",
    "@types/node": "^22.19.21",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/ui": "^4.0.18",
    "bun-types": "^1.3.14",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "nx": "22.7.5",
    "oclif": "4.23.14",
    "rimraf": "^6.1.2",
    "string-width": "4.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "axios": "^1.17.0",
    "typescript": "^5.9.3",
    "@types/node": "^22.19.21",
    "rimraf": "^6.1.2"
  },
  "patchedDependencies": {
    "effect-orpc@0.5.0": "patches/effect-orpc@0.5.0.patch"
  }
}
