{
  "name": "civ7-modding-tools",
  "version": "1.3.0",
  "description": "CLI tools and utilities for Civilization VII modding, including resource extraction, graph visualization, and XML analysis",
  "keywords": [
    "civilization-vii",
    "civ7",
    "modding",
    "tools",
    "cli",
    "xml",
    "graph-visualization",
    "typescript",
    "game-modding",
    "resource-extraction"
  ],
  "homepage": "https://github.com/mateicanavra/civ7-modding-tools-fork#readme",
  "bugs": {
    "url": "https://github.com/mateicanavra/civ7-modding-tools-fork/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateicanavra/civ7-modding-tools-fork.git"
  },
  "license": "MIT",
  "author": "Matei <tools@matei.work>",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*",
    "mods/*",
    "tools/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "check": "nx run-many -t check",
    "ci": "nx run-many -t build,check,test",
    "clean": "nx run-many -t clean",
    "deploy:mods": "nx run-many -t deploy",
    "docs:project": "nx run habitat:serve:project-docs",
    "effect:init": "bash ./scripts/effect-submodule/init-submodule.sh",
    "effect:status": "bash ./scripts/effect-submodule/status.sh",
    "format": "nx run habitat:format",
    "gt:import-pr": "bash ./scripts/graphite-import-pr.sh",
    "gt:import-worktree": "bash ./scripts/graphite-import-worktree.sh",
    "habitat": "bun tools/habitat/bin/dev.ts",
    "lint": "nx run habitat:lint",
    "openspec": "openspec",
    "openspec:validate": "openspec validate --all --strict",
    "prepare": "husky",
    "refresh:data": "bun run resources:init && nx run civ7-cli:data:zip:default && nx run civ7-cli:data:unzip:default",
    "resources:init": "bash ./packages/cli/scripts/resources-submodule/init-submodule.sh",
    "resources:publish": "bash ./packages/cli/scripts/resources-submodule/publish-submodule.sh",
    "resources:status": "bash ./packages/cli/scripts/resources-submodule/status.sh",
    "resources:unlock": "python3 ./packages/cli/scripts/resources-submodule/unlock-submodule.py",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "verify": "nx run-many -t verify"
  },
  "overrides": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^22.19.21",
    "axios": "^1.17.0",
    "rimraf": "^6.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@catenarycloud/linteffect": "0.0.6",
    "@fission-ai/openspec": "^1.3.1",
    "@getgrit/cli": "0.1.0-alpha.1743007075",
    "@nx/eslint-plugin": "23.1.0",
    "@types/node": "^22.19.21",
    "@typescript-eslint/parser": "^8.54.0",
    "@typescript/native": "npm:typescript@7.0.2",
    "@typescript/typescript6": "6.0.2",
    "@vitest/ui": "^4.0.18",
    "bun-types": "^1.3.14",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "nx": "23.1.0",
    "oclif": "4.23.14",
    "rimraf": "^6.1.2",
    "sort-package-json": "4.0.0",
    "string-width": "4.2.3",
    "tsup": "^8.5.1",
    "type-fest": "^5.7.0",
    "typescript": "6.0.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "22.22.0"
  },
  "catalog": {
    "effect-orpc": "0.5.0",
    "typebox": "1.3.6"
  },
  "patchedDependencies": {
    "effect-orpc@0.5.0": "patches/effect-orpc@0.5.0.patch",
    "tsup@8.5.1": "patches/tsup@8.5.1.patch",
    "@catenarycloud/linteffect@0.0.6": "patches/@catenarycloud%2Flinteffect@0.0.6.patch"
  },
  "trustedDependencies": [
    "@getgrit/cli",
    "docsify",
    "esbuild",
    "nx",
    "puppeteer",
    "sharp"
  ]
}
