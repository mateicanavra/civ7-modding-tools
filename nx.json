{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [
    {
      "plugin": "./tools/habitat/src/nx-plugin.ts",
      "options": {
        "checkTargetName": "check:policy"
      }
    }
  ],
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/tsconfig*.json"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "{projectRoot}/dist/**",
        "{projectRoot}/types/**",
        "{projectRoot}/example-generated-mod/**",
        "{projectRoot}/mod/**"
      ],
      "cache": true
    },
    "deploy": {
      "dependsOn": [
        "build",
        {
          "projects": ["civ7-cli"],
          "target": "build"
        }
      ],
      "cache": false
    },
    "dev": {
      "cache": false,
      "continuous": true
    },
    "check": {
      "dependsOn": ["typecheck", "check:policy", "^check"],
      "cache": false,
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": []
    },
    "lint": {
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^default", "{workspaceRoot}/vitest.config.ts"]
    },
    "verify": {
      "dependsOn": ["build", "^build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  },
  "analytics": false
}
