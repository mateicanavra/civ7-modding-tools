{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [
    {
      "plugin": "./tools/habitat/src/nx-plugin.ts",
      "options": {
        "checkTargetName": "check:policy"
      }
    }
  ],
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/tsconfig*.json"],
    "typescriptRuntime": ["{workspaceRoot}/package.json", "{workspaceRoot}/bun.lock"],
    "habitatRuntime": [
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/bun.lock",
      "{workspaceRoot}/bunfig.toml",
      "{workspaceRoot}/tsconfig*.json",
      "{workspaceRoot}/tools/habitat/bin/**",
      "{workspaceRoot}/tools/habitat/src/**",
      "{workspaceRoot}/tools/habitat/package.json",
      "{workspaceRoot}/tools/habitat/tsconfig*.json",
      { "env": "HABITAT_HARNESS_ROOT" },
      { "env": "HABITAT_CACHE_ROOT" },
      { "env": "HABITAT_PATTERN_CACHE_ROOT" },
      { "env": "HABITAT_TELEMETRY_DISABLED" },
      { "env": "HABITAT_COMMAND_TIMEOUT_MS" }
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "{projectRoot}/dist/**",
        "{projectRoot}/types/**",
        "{projectRoot}/example-generated-mod/**",
        "{projectRoot}/mod/**"
      ],
      "cache": true
    },
    "deploy": {
      "dependsOn": [
        "build",
        {
          "projects": ["civ7-cli"],
          "target": "build"
        }
      ],
      "cache": false
    },
    "dev": {
      "cache": false,
      "continuous": true
    },
    "check": {
      "dependsOn": ["typecheck", "check:policy", "^check"],
      "cache": false,
      "outputs": []
    },
    "check:test": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^default", "typescriptRuntime"],
      "outputs": []
    },
    "check:tools": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^default", "typescriptRuntime"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["check:test", "check:tools", "^build"],
      "cache": true,
      "inputs": ["default", "^default", "typescriptRuntime"],
      "outputs": []
    },
    "lint": {
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^default", "{workspaceRoot}/vitest.config.ts"]
    },
    "verify": {
      "dependsOn": ["build", "^build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  },
  "analytics": false
}
