{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "plugins": [
    {
      "plugin": "./tools/habitat/src/nx-plugin.ts",
      "options": {
        "checkTargetName": "habitat:check",
        "boundariesTargetName": "boundaries",
        "biomeFormatTargetName": "biome:format",
        "biomeCheckTargetName": "biome:check",
        "biomeCiTargetName": "biome:ci"
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "{projectRoot}/dist/**",
        "{projectRoot}/types/**",
        "{projectRoot}/example-generated-mod/**",
        "{projectRoot}/mod/**"
      ],
      "cache": true
    },
    "deploy": {
      "dependsOn": [
        "build",
        {
          "projects": ["@mateicanavra/civ7-cli"],
          "target": "build"
        }
      ],
      "cache": false
    },
    "habitat:check": {
      "dependsOn": [
        "build",
        {
          "projects": ["@habitat/cli"],
          "target": "build"
        }
      ],
      "cache": true
    },
    "dev": {
      "cache": false,
      "continuous": true
    },
    "check": {
      "dependsOn": ["^build", "^check"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "verify": {
      "dependsOn": ["build", "^build"],
      "cache": false
    },
    "clean": {
      "cache": true
    }
  },
  "analytics": false
}
