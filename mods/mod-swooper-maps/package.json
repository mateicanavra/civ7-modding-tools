{
  "name": "mod-swooper-maps",
  "version": "0.1.0",
  "private": true,
  "description": "Swooper Maps mod for Civilization VII",
  "type": "module",
  "exports": {
    "./recipes/studio-contracts": {
      "types": "./src/recipes/studio-contracts/index.ts",
      "import": "./src/recipes/studio-contracts/index.ts"
    },
    "./maps/catalog": {
      "types": "./src/maps/catalog/index.ts",
      "import": "./src/maps/catalog/index.ts"
    },
    "./maps/configs/canonical": {
      "types": "./src/maps/configs/canonical.ts",
      "import": "./src/maps/configs/canonical.ts"
    },
    "./maps/configs/standard-admission": {
      "types": "./src/maps/configs/standard-admission.ts",
      "import": "./src/maps/configs/standard-admission.ts"
    },
    "./recipes/standard": {
      "types": "./dist/recipes/standard.d.ts",
      "import": "./dist/recipes/standard.js"
    },
    "./recipes/standard-artifacts": {
      "types": "./dist/recipes/standard-artifacts.d.ts",
      "import": "./dist/recipes/standard-artifacts.js"
    },
    "./recipes/standard-map-configs": {
      "types": "./dist/recipes/standard-map-configs.d.ts",
      "import": "./dist/recipes/standard-map-configs.js"
    }
  },
  "scripts": {
    "diag:analyze": "bun ./scripts/diagnostics/analyze-dump.ts",
    "diag:diff": "bun ./scripts/diagnostics/diff-layers.ts",
    "diag:list": "bun ./scripts/diagnostics/list-layers.ts",
    "diag:trace": "bun ./scripts/diagnostics/extract-trace.ts",
    "metrics:report": "bun ./scripts/metrics/report.ts"
  },
  "dependencies": {
    "@civ7/adapter": "workspace:*",
    "@civ7/map-policy": "workspace:*",
    "@civ7/studio-contract": "workspace:*",
    "@civ7/studio-run-workspace": "workspace:*",
    "@mateicanavra/civ7-sdk": "workspace:*",
    "@swooper/mapgen-core": "workspace:*",
    "@swooper/mapgen-diagnostics": "workspace:*",
    "@swooper/mapgen-metrics": "workspace:*",
    "@swooper/mapgen-viz": "workspace:*",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@civ7/control-orpc": "workspace:*",
    "@civ7/direct-control": "workspace:*",
    "@civ7/plugin-mods": "workspace:*",
    "@civ7/types": "workspace:*",
    "@orpc/client": "1.14.6",
    "@orpc/contract": "1.14.6",
    "esbuild": "^0.27.2",
    "json-schema-to-typescript": "^15.0.4",
    "type-fest": "^5.7.0"
  }
}
