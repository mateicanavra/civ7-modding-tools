{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "mod-swooper-maps",
  "tags": ["kind:mod"],
  "targets": {
    "build": {
      "command": "tsup",
      "dependsOn": ["^build", "gen:maps"],
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/mod/**", "{projectRoot}/src/maps/generated/**"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "build:studio-recipes": {
      "command": "node -e \"\"",
      "cache": false,
      "outputs": ["{projectRoot}/dist/recipes/**"],
      "dependsOn": ["gen:studio-recipes-types", "gen:studio-map-catalog"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "build:studio-deploy": {
      "command": "tsup",
      "inputs": [
        "default",
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_ID"
        },
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_PATH"
        },
        {
          "env": "SWOOPER_STUDIO_RUN_ID"
        },
        {
          "env": "SWOOPER_STUDIO_LAUNCH_CONFIG_ID"
        },
        {
          "env": "SWOOPER_STUDIO_LAUNCH_ENVELOPE_DIGEST"
        }
      ],
      "outputs": ["{projectRoot}/mod/**", "{projectRoot}/src/maps/generated/**"],
      "dependsOn": ["^build", "gen:studio-deploy-map-artifacts"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "check": {
      "command": "tsc --noEmit",
      "dependsOn": ["^build", "build"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "test": {
      "command": "bun test",
      "dependsOn": ["^build", "build:studio-recipes", "habitat:check"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "test:studio-run-in-game": {
      "command": "bun test test/standard-run.test.ts test/build/map-bundle-runtime-imports.test.ts test/config/maps-schema-valid.test.ts test/config/shipped-map-identity.test.ts",
      "dependsOn": ["build:studio-recipes"],
      "cache": true,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:configs:shape-check": {
      "command": "bun ./scripts/migrate-config-shapes.ts --dry",
      "dependsOn": [
        {
          "projects": ["mapgen-core"],
          "target": "build"
        }
      ],
      "inputs": ["default", "^default"],
      "cache": true,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:map-artifacts": {
      "command": "bun ./scripts/generate-map-artifacts.ts",
      "dependsOn": [
        {
          "projects": ["mapgen-core"],
          "target": "build"
        }
      ],
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/mod/**", "{projectRoot}/src/maps/generated/**"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:studio-deploy-map-artifacts": {
      "command": "bun ./scripts/generate-map-artifacts.ts --include-studio-deploy-config",
      "dependsOn": [
        {
          "projects": ["mapgen-core"],
          "target": "build"
        }
      ],
      "inputs": [
        "default",
        "^default",
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_ID"
        },
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_PATH"
        },
        {
          "env": "SWOOPER_STUDIO_RUN_ID"
        },
        {
          "env": "SWOOPER_STUDIO_LAUNCH_CONFIG_ID"
        },
        {
          "env": "SWOOPER_STUDIO_LAUNCH_ENVELOPE_DIGEST"
        }
      ],
      "outputs": ["{projectRoot}/mod/**", "{projectRoot}/src/maps/generated/**"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:maps": {
      "command": "node -e \"\"",
      "dependsOn": ["gen:map-artifacts"],
      "cache": false,
      "outputs": ["{projectRoot}/mod/**", "{projectRoot}/src/maps/generated/**"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:run-manifest": {
      "command": "bun ./scripts/generate-run-manifest.ts",
      "dependsOn": ["build:studio-recipes:bundle", { "projects": ["civ7-sdk"], "target": "build" }],
      "inputs": ["default", "^default", "{workspaceRoot}/packages/studio-run-workspace/src/**"],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "build:studio-recipes:bundle": {
      "command": "tsup --config tsup.studio-recipes.config.ts",
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/dist/recipes/standard.js"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:studio-recipes-types": {
      "command": "bun ./scripts/generate-studio-recipe-types.ts",
      "dependsOn": ["build:studio-recipes:bundle"],
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/recipes/standard.schema.json",
        "{projectRoot}/dist/recipes/standard.defaults.json",
        "{projectRoot}/dist/recipes/standard.presets.json",
        "{projectRoot}/dist/recipes/standard.d.ts",
        "{projectRoot}/dist/recipes/standard-artifacts.js",
        "{projectRoot}/dist/recipes/standard-artifacts.d.ts"
      ],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:studio-map-catalog": {
      "command": "bun ./scripts/generate-studio-map-catalog.ts",
      "dependsOn": [
        {
          "projects": ["mapgen-core"],
          "target": "build"
        }
      ],
      "inputs": [
        "default",
        "^default",
        "{projectRoot}/src/maps/catalog/index.ts",
        "{projectRoot}/src/maps/catalog/sourceIndex.ts",
        "{projectRoot}/src/maps/catalog/sources.ts"
      ],
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/recipes/standard-map-config.schema.json",
        "{projectRoot}/dist/recipes/standard-map-configs.js",
        "{projectRoot}/dist/recipes/standard-map-configs.d.ts"
      ],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "viz:standard": {
      "command": "bun ./src/dev/viz/standard-run.ts",
      "dependsOn": ["viz:runtime-deps"],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "diag:dump": {
      "command": "bun ./src/dev/diagnostics/run-standard-dump.ts",
      "dependsOn": ["viz:runtime-deps"],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "viz:runtime-deps": {
      "command": "node ./scripts/ensure-viz-runtime-deps.mjs",
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "deploy": {
      "command": "node ../../packages/cli/bin/run.js mod manage deploy --input \"$PWD/mod\" --id mod-swooper-maps",
      "dependsOn": [
        "build",
        {
          "projects": ["civ7-cli"],
          "target": "build"
        }
      ],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    }
  }
}
