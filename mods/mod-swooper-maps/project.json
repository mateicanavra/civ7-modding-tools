{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "mod-swooper-maps",
  "tags": ["kind:mod"],
  "targets": {
    "build": {
      "command": "tsup --config scripts/tsup.config.ts",
      "dependsOn": ["^build", "generated:check"],
      "inputs": ["default", "^default"],
      "outputs": ["{projectRoot}/mod/maps/**"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "build:studio-recipes": {
      "command": "node -e \"\"",
      "cache": false,
      "outputs": [],
      "dependsOn": ["gen:studio-recipes-types", "gen:studio-map-catalog"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "build:studio-deploy": {
      "command": "tsup --config scripts/tsup.config.ts",
      "inputs": [
        "default",
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_ID"
        },
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_PATH"
        }
      ],
      "outputs": ["{projectRoot}/mod/maps/**"],
      "dependsOn": ["^build", "gen:studio-deploy-map-artifacts"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "dependsOn": ["check:test", "check:tools", "build"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "check:test": {
      "command": "tsc -p test/tsconfig.json --noEmit",
      "dependsOn": ["build:studio-recipes"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "check:tools": {
      "command": "tsc -p scripts/tsconfig.json --noEmit",
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "check": {
      "executor": "nx:noop",
      "cache": false,
      "outputs": []
    },
    "test": {
      "command": "bun test",
      "dependsOn": ["build", "build:studio-recipes"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "test:studio-run-in-game": {
      "command": "bun test test/recipes/swooper-physics-standard/generation.test.ts test/recipes/swooper-physics-standard/complete-config-boundary.test.ts test/build/map-bundle-runtime-compatibility.test.ts test/maps/map-config-schema.test.ts",
      "dependsOn": ["build", "build:studio-recipes"],
      "cache": true,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "verify:operational": {
      "command": "bun ./scripts/verify.ts",
      "dependsOn": ["build"],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:map-artifacts": {
      "command": "bun ./scripts/generate-map-artifacts.ts",
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^default",
        "!{projectRoot}/src/maps/generated/**",
        "!{projectRoot}/mod/config/config.xml",
        "!{projectRoot}/mod/swooper-maps.modinfo",
        "!{projectRoot}/mod/data/biome-hazards.xml",
        "!{projectRoot}/mod/text/en_us/MapText.xml"
      ],
      "outputs": [
        "{projectRoot}/src/maps/generated/**",
        "{projectRoot}/mod/config/config.xml",
        "{projectRoot}/mod/swooper-maps.modinfo",
        "{projectRoot}/mod/data/biome-hazards.xml",
        "{projectRoot}/mod/text/en_us/MapText.xml"
      ],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:studio-deploy-map-artifacts": {
      "command": "bun ./scripts/generate-map-artifacts.ts --include-studio-deploy-config",
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^default",
        "!{projectRoot}/src/maps/generated/**",
        "!{projectRoot}/mod/config/config.xml",
        "!{projectRoot}/mod/swooper-maps.modinfo",
        "!{projectRoot}/mod/data/biome-hazards.xml",
        "!{projectRoot}/mod/text/en_us/MapText.xml",
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_ID"
        },
        {
          "env": "SWOOPER_STUDIO_DEPLOY_CONFIG_PATH"
        }
      ],
      "outputs": [
        "{projectRoot}/src/maps/generated/**",
        "{projectRoot}/mod/config/config.xml",
        "{projectRoot}/mod/swooper-maps.modinfo",
        "{projectRoot}/mod/data/biome-hazards.xml",
        "{projectRoot}/mod/text/en_us/MapText.xml"
      ],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:maps": {
      "command": "node -e \"\"",
      "dependsOn": ["gen:map-artifacts"],
      "cache": false,
      "outputs": [],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "generated:check": {
      "command": "bun ./scripts/generate-map-artifacts.ts --check",
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"],
      "cache": true,
      "outputs": [],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:run-manifest": {
      "command": "bun ./scripts/generate-run-manifest.ts",
      "dependsOn": ["^build"],
      "inputs": ["default", "^default", "{workspaceRoot}/packages/studio-run-workspace/src/**"],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "build:studio-recipes:bundle": {
      "command": "tsup --config scripts/tsup.studio-recipes.config.ts",
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/dist/recipes/standard.js"],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:studio-recipes-types": {
      "command": "bun ./scripts/generate-studio-recipe-types.ts",
      "dependsOn": ["build:studio-recipes:bundle"],
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/recipes/standard.schema.json",
        "{projectRoot}/dist/recipes/standard.defaults.json",
        "{projectRoot}/dist/recipes/standard.d.ts",
        "{projectRoot}/dist/recipes/standard-artifacts.js",
        "{projectRoot}/dist/recipes/standard-artifacts.d.ts"
      ],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "gen:studio-map-catalog": {
      "command": "bun ./scripts/generate-studio-map-catalog.ts",
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^default",
        "{projectRoot}/src/maps/catalog/index.ts",
        "{projectRoot}/src/maps/catalog/sourceIndex.ts",
        "{projectRoot}/src/maps/catalog/sources.ts"
      ],
      "cache": true,
      "outputs": [
        "{projectRoot}/dist/recipes/standard-map-config.schema.json",
        "{projectRoot}/dist/recipes/standard-map-configs.js",
        "{projectRoot}/dist/recipes/standard-map-configs.d.ts"
      ],
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "viz:standard": {
      "command": "bun ./scripts/diagnostics/standard-run.ts",
      "dependsOn": ["viz:runtime-deps"],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "diag:dump": {
      "command": "bun ./scripts/diagnostics/run-standard-dump.ts",
      "dependsOn": ["viz:runtime-deps"],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    },
    "diag:analyze": {
      "dependsOn": [
        {
          "projects": ["mapgen-diagnostics"],
          "target": "build"
        },
        {
          "projects": ["mapgen-core"],
          "target": "build"
        },
        {
          "projects": ["mapgen-metrics"],
          "target": "build"
        }
      ]
    },
    "diag:diff": {
      "dependsOn": [
        {
          "projects": ["mapgen-diagnostics"],
          "target": "build"
        }
      ]
    },
    "diag:list": {
      "dependsOn": [
        {
          "projects": ["mapgen-diagnostics"],
          "target": "build"
        }
      ]
    },
    "diag:trace": {
      "dependsOn": [
        {
          "projects": ["mapgen-diagnostics"],
          "target": "build"
        }
      ]
    },
    "viz:runtime-deps": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": ["civ7-adapter"],
          "target": "build"
        },
        {
          "projects": ["mapgen-core"],
          "target": "build"
        },
        {
          "projects": ["mapgen-viz"],
          "target": "build"
        },
        {
          "projects": ["mapgen-diagnostics"],
          "target": "build"
        }
      ],
      "cache": false,
      "outputs": []
    },
    "deploy": {
      "command": "node ../../packages/cli/bin/run.js mod manage deploy --input \"$PWD/mod\" --id mod-swooper-maps",
      "dependsOn": [
        "build",
        {
          "projects": ["civ7-cli"],
          "target": "build"
        }
      ],
      "cache": false,
      "options": {
        "cwd": "mods/mod-swooper-maps"
      }
    }
  }
}
